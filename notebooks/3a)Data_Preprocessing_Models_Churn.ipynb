    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 9. Feature Importance\\n\",\n",
    "    \"\\n\",\n",
    "    \"Extract and visualise the **top-20 most important features** according to the\\n\",\n",
    "    \"tuned model. For tree-based models (HistGBM, Random Forest) the built-in\\n\",\n",
    "    \"`feature_importances_` attribute is used. For Logistic Regression the absolute\\n\",\n",
    "    \"value of the coefficients is used instead.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"47f9552c\",\n",
    "   \"metadata\": {\n",
    "    \"execution\": {\n",
    "     \"iopub.execute_input\": \"2026-03-13T12:11:48.390504Z\",\n",
    "     \"iopub.status.busy\": \"2026-03-13T12:11:48.390321Z\",\n",
    "     \"iopub.status.idle\": \"2026-03-13T12:12:20.620400Z\",\n",
    "     \"shell.execute_reply\": \"2026-03-13T12:12:20.619268Z\"\n",
    "    },\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-14T19:15:11.324200600Z\",\n",
    "     \"start_time\": \"2026-03-14T19:14:57.560665200Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Compute feature importances\\n\",\n",
    "    \"# For tree-based models that expose .feature_importances_ (e.g. RF) we use the built-in attribute.  \\n\",\n",
    "    \"# For models that do not (e.g. HistGBM in sklearn<1.6, Logistic Regression) we fall back to permutation importance, which\\n\",\n",
    "    \"# measures how much the score drops when a feature is randomly shuffled.\\n\",\n",
    "    \"\\n\",\n",
    "    \"if hasattr(final_model, 'feature_importances_'):\\n\",\n",
    "    \"    # Built-in importance (mean decrease in impurity / gain)\\n\",\n",
    "    \"    importances = final_model.feature_importances_\\n\",\n",
    "    \"    importance_type = \\\"built-in\\\"\\n\",\n",
    "    \"elif hasattr(final_model, 'coef_'):\\n\",\n",
    "    \"    # Linear models - absolute coefficient values as an importance proxy\\n\",\n",
    "    \"    importances = np.abs(final_model.coef_[0])\\n\",\n",
    "    \"    importance_type = \\\"coefficient-based\\\"\\n\",\n",
    "    \"else:\\n\",\n",
    "    \"    # Permutation importance - model-agnostic, works for any estimator\\n\",\n",
    "    \"    # Measures the drop in ROC-AUC when each feature is randomly shuffled\\n\",\n",
    "    \"    print(\\\"Computing permutation importance (this may take a moment)...\\\")\\n\",\n",
    "    \"    perm_result = permutation_importance(\\n\",\n",
    "    \"        final_model,\\n\",\n",
    "    \"        X_test_fs,               # use test set for unbiased importance\\n\",\n",
    "    \"        y_test,\\n\",\n",
    "    \"        n_repeats=10,            # repeat the shuffle 10 times for stability\\n\",\n",
    "    \"        scoring='roc_auc',\\n\",\n",
    "    \"        random_state=RANDOM_STATE,\\n\",\n",
    "    \"        n_jobs=-1,\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    importances = perm_result.importances_mean\\n\",\n",
    "    \"    importance_type = \\\"permutation\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Importance method used: {importance_type}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Build a Series for easy sorting and plotting\\n\",\n",
    "    \"feat_imp = pd.Series(importances, index=selected_features).sort_values(ascending=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Display the top-20 features as a horizontal bar chart \\n\",\n",
    "    \"TOP_N = 20\\n\",\n",
    "    \"top_features = feat_imp.head(TOP_N)\\n\",\n",
    "    \"\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(10, 7))\\n\",\n",
    "    \"# sort ascending so the largest bar appears at the top of the horizontal chart\\n\",\n",
    "    \"top_features.sort_values().plot.barh(ax=ax, color='steelblue', edgecolor='black')\\n\",\n",
    "    \"ax.set_xlabel(f'Feature Importance ({importance_type})')\\n\",\n",
    "    \"ax.set_title(f'Top {TOP_N} Feature Importances - {best_model_name}')\\n\",\n",
    "    \"plt.tight_layout()\\n\",\n",
    "    \"plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Print the full ranking\\n\",\n",
    "    \"print(f\\\"\\\\nAll {len(feat_imp)} features ranked by importance:\\\\n\\\")\\n\",\n",
    "    \"print(feat_imp.to_string())\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Computing permutation importance (this may take a moment)...\\n\",\n",
    "      \"Importance method used: permutation\\n\"\n",
    "     ]\n",
