    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5. Feature Selection\\n\",\n",
    "    \"\\n\",\n",
    "    \"Feature selection is applied on `X_train_df` only.\\n\",\n",
    "    \"The same selected columns are then applied to `X_test_df`.\\n\",\n",
    "    \"\\n\",\n",
    "    \"**No leakage here because:**\\n\",\n",
    "    \"- All selection criteria (variance, correlation) are computed on `X_train_df`\\n\",\n",
    "    \"- `X_test_df` is only filtered at the end using the mask learned from train\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"02e7b7b7\",\n",
    "   \"metadata\": {\n",
    "    \"execution\": {\n",
    "     \"iopub.execute_input\": \"2026-03-13T12:09:42.044817Z\",\n",
    "     \"iopub.status.busy\": \"2026-03-13T12:09:42.044657Z\",\n",
    "     \"iopub.status.idle\": \"2026-03-13T12:09:43.144836Z\",\n",
    "     \"shell.execute_reply\": \"2026-03-13T12:09:43.143011Z\"\n",
    "    },\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-14T19:10:55.147535600Z\",\n",
    "     \"start_time\": \"2026-03-14T19:10:54.819759600Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"#  5a. Remove constant / quasi-constant features \\n\",\n",
    "    \"# VarianceThreshold(0.01) drops features whose variance is below 0.01.\\n\",\n",
    "    \"# After StandardScaler most features have variance ≈ 1, so this threshold\\n\",\n",
    "    \"# is intentionally very low — it only catches truly constant columns.\\n\",\n",
    "    \"print(f\\\"Initial features: {X_train_df.shape[1]}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"var_thresh = VarianceThreshold(threshold=0.01)\\n\",\n",
    "    \"var_thresh.fit(X_train_df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Boolean mask of features that passed the variance filter\\n\",\n",
    "    \"var_mask = var_thresh.get_support()\\n\",\n",
    "    \"features_after_var = X_train_df.columns[var_mask].tolist()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Report any removed features\\n\",\n",
    "    \"removed_by_var = X_train_df.columns[~var_mask].tolist()\\n\",\n",
    "    \"print(f\\\"Features after VarianceThreshold (th=0.01): {len(features_after_var)}\\\")\\n\",\n",
    "    \"if removed_by_var:\\n\",\n",
    "    \"    print(f\\\"  Removed (near-zero variance): {removed_by_var}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Subset the training DF for the next step\\n\",\n",
    "    \"X_train_var = X_train_df[features_after_var]\\n\",\n",
    "    \"\\n\",\n",
    "    \"#  5b. Iterative correlation-based feature removal \\n\",\n",
    "    \"# Instead of dropping EVERY feature that has any partner above the\\n\",\n",
    "    \"# threshold, we iteratively remove the feature with the MOST\\n\",\n",
    "    \"# high-correlation partners.  This preserves maximum information.\\n\",\n",
    "    \"\\n\",\n",
    "    \"CORR_THRESHOLD = 0.90\\n\",\n",
    "    \"corr_matrix = X_train_var.corr().abs()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Zero out the diagonal and lower triangle\\n\",\n",
    "    \"upper = corr_matrix.where(\\n\",\n",
    "    \"    np.triu(np.ones(corr_matrix.shape), k=1).astype(bool)\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"to_drop = []\\n\",\n",
    "    \"drop_reasons = {}   # feature  list of correlated partners that caused removal\\n\",\n",
    "    \"\\n\",\n",
    "    \"while True:\\n\",\n",
    "    \"    # Count how many high-corr partners each remaining feature has\\n\",\n",
    "    \"    high_corr_counts = (upper > CORR_THRESHOLD).sum()\\n\",\n",
    "    \"    max_count = high_corr_counts.max()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if max_count == 0:\\n\",\n",
    "    \"        break   # no more high correlations\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Pick the feature with the most high-corr partners\\n\",\n",
    "    \"    worst_feature = high_corr_counts.idxmax()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Record which partners triggered the drop (for audit trail)\\n\",\n",
    "    \"    partners = upper.columns[upper[worst_feature] > CORR_THRESHOLD].tolist()\\n\",\n",
    "    \"    partners += upper.index[upper.loc[:, worst_feature] > CORR_THRESHOLD].tolist() if worst_feature in upper.columns else []\\n\",\n",
    "    \"    drop_reasons[worst_feature] = list(set(partners))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    to_drop.append(worst_feature)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Remove this feature from the correlation matrix entirely\\n\",\n",
    "    \"    upper = upper.drop(index=worst_feature, columns=worst_feature)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nHighly correlated features to drop (>{CORR_THRESHOLD}): {len(to_drop)}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Print pair-level audit trail\\n\",\n",
    "    \"if to_drop:\\n\",\n",
    "    \"    for feat in to_drop:\\n\",\n",
    "    \"        partners_str = \\\", \\\".join(drop_reasons[feat][:5])\\n\",\n",
    "    \"        extra = f\\\" (+{len(drop_reasons[feat])-5} more)\\\" if len(drop_reasons[feat]) > 5 else \\\"\\\"\\n\",\n",
    "    \"        print(f\\\"   {feat}   correlated with: {partners_str}{extra}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"#  5c. Build the final selected feature list \\n\",\n",
    "    \"selected_features = [f for f in features_after_var if f not in to_drop]\\n\",\n",
    "    \"print(f\\\"\\\\nFeatures after selection: {len(selected_features)}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Apply the same mask to both train and test\\n\",\n",
    "    \"X_train_fs = X_train_df[selected_features]\\n\",\n",
    "    \"X_test_fs  = X_test_df[selected_features]\\n\",\n",
    "    \"\\n\",\n",
    "    \"#  Sanity check: both sets must have identical columns \\n\",\n",
    "    \"assert list(X_train_fs.columns) == list(X_test_fs.columns), (\\n\",\n",
    "    \"    \\\"Train and test feature sets have different columns after selection!\\\"\\n\",\n",
    "    \")\\n\",\n",
    "    \"print(f\\\" Train and test share the same {len(selected_features)} columns.\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Initial features: 88\\n\",\n",
    "      \"Features after VarianceThreshold (th=0.01): 66\\n\",\n",
    "      \"  Removed (near-zero variance): ['sdem_HABITAT_0', 'sdem_HABITAT_E', 'sdem_HABITAT_O', 'sdem_HABITAT_X', 'CSP_0.0', 'CSP_10.0', 'CSP_25.0', 'CSP_33.0', 'CSP_34.0', 'CSP_40.0', 'CSP_50.0', 'CSP_51.0', 'CSP_52.0', 'CSP_53.0', 'CSP_54.0', 'CSP_55.0', 'CSP_57.0', 'CSP_58.0', 'CSP_81.0', 'CSP_86.0', 'CSP_96.0', 'CSP_99.0']\\n\",\n",
    "      \"\\n\",\n",
    "      \"Highly correlated features to drop (>0.9): 8\\n\",\n",
    "      \"   MEDIAN_DURDEG   correlated with: MIN_DURDEG, MAX_DURDEG\\n\",\n",
    "      \"   MEDIAN_RANGPRO   correlated with: MAX_RANGPRO, MIN_RANGPRO\\n\",\n",
    "      \"   MEDIAN_RANGCLI   correlated with: MAX_RANGCLI, MIN_RANGCLI\\n\",\n",
    "      \"   MEDIAN_RESSO   correlated with: MIN_RESSO, MAX_RESSO\\n\",\n",
    "      \"   MAX_RANGCLI   correlated with: MIN_RANGCLI\\n\",\n",
    "      \"   TOTAL_MTFINO   correlated with: TOTAL_MTFIN\\n\",\n",
    "      \"   ALLBD_N_events__N   correlated with: ALLBD_N_Dossiers__N\\n\",\n",
    "      \"   sdem_HABITAT_Unknown   correlated with: sdem_SITFAM_Unknown\\n\",\n",
    "      \"\\n\",\n",
    "      \"Features after selection: 58\\n\",\n",
    "      \" Train and test share the same 58 columns.\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 9\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"8bbe78c8\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6. Model Comparison\\n\",\n",
    "    \"\\n\",\n",
    "    \"Quick baseline comparison across models using cross-validation on `X_train_fs`.\\n\",\n",
    "    \"Pick the best baseline before investing time in hyperparameter tuning.\\n\",\n",
    "    \"\\n\",\n",
    "    \"We include **train scores** alongside test scores so we can check for overfitting.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"a2375d95\",\n",
    "   \"metadata\": {\n",
    "    \"execution\": {\n",
    "     \"iopub.execute_input\": \"2026-03-13T12:09:43.150522Z\",\n",
    "     \"iopub.status.busy\": \"2026-03-13T12:09:43.150300Z\",\n",
    "     \"iopub.status.idle\": \"2026-03-13T12:10:18.709165Z\",\n",
    "     \"shell.execute_reply\": \"2026-03-13T12:10:18.708510Z\"\n",
    "    },\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-14T19:11:34.157986600Z\",\n",
    "     \"start_time\": \"2026-03-14T19:10:55.148534Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Define baseline models with sensible defaults\\n\",\n",
    "    \"models = {\\n\",\n",
    "    \"    'Logistic Regression': ImbPipeline([\\n\",\n",
    "    \"        ('smote', SMOTE(random_state=RANDOM_STATE)),\\n\",\n",
    "    \"        ('model', LogisticRegression(max_iter=1000, random_state=RANDOM_STATE)),\\n\",\n",
    "    \"    ]),\\n\",\n",
    "    \"\\n\",\n",
    "    \"    'Random Forest': ImbPipeline([\\n\",\n",
    "    \"        ('smote', SMOTE(random_state=RANDOM_STATE)),\\n\",\n",
    "    \"        ('model', RandomForestClassifier(n_estimators=100, n_jobs=-1, random_state=RANDOM_STATE)),\\n\",\n",
    "    \"    ]),\\n\",\n",
    "    \"\\n\",\n",
    "    \"    'HistGBM': ImbPipeline([\\n\",\n",
    "    \"        ('smote', SMOTE(random_state=RANDOM_STATE)),\\n\",\n",
    "    \"        ('model', HistGradientBoostingClassifier(random_state=RANDOM_STATE, max_iter=100)),\\n\",\n",
    "    \"    ]),\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Cross-validate each model  ← NADA MUDA DAQUI PARA BAIXO\\n\",\n",
    "    \"results = []\\n\",\n",
    "    \"for name, model in models.items():\\n\",\n",
    "    \"    print(f\\\"Training {name}...\\\")\\n\",\n",
    "    \"    cv_res = cross_validate(\\n\",\n",
    "    \"        model,\\n\",\n",
    "    \"        X_train_fs,\\n\",\n",
    "    \"        y_train,\\n\",\n",
    "    \"        cv=cv,\\n\",\n",
    "    \"        scoring='roc_auc',\\n\",\n",
    "    \"        n_jobs=-1,\\n\",\n",
    "    \"        return_train_score=True,\\n\",\n",
    "    \"    )\\n\",\n",
    "    \"    results.append({\\n\",\n",
    "    \"        'Model': name,\\n\",\n",
    "    \"        'Train ROC-AUC': cv_res['train_score'].mean(),\\n\",\n",
    "    \"        'Val ROC-AUC':   cv_res['test_score'].mean(),\\n\",\n",
    "    \"        'Std Val AUC':   cv_res['test_score'].std(),\\n\",\n",
    "    \"    })\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Display results sorted by validation AUC\\n\",\n",
    "    \"results_df = pd.DataFrame(results).sort_values(by='Val ROC-AUC', ascending=False)\\n\",\n",
    "    \"display(results_df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Select the best baseline model for tuning\\n\",\n",
    "    \"best_model_name = results_df.iloc[0]['Model']\\n\",\n",
    "    \"best_model = models[best_model_name]\\n\",\n",
    "    \"print(f\\\"\\\\nSelected {best_model_name} as the best baseline model.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Overfitting check\\n\",\n",
    "    \"for _, row in results_df.iterrows():\\n\",\n",
    "    \"    gap = row['Train ROC-AUC'] - row['Val ROC-AUC']\\n\",\n",
    "    \"    if gap > 0.05:\\n\",\n",
    "    \"        print(f\\\"CAUTION!  {row['Model']}: train-val gap = {gap:.4f} - possible overfitting\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Training Logistic Regression...\\n\",\n",
    "      \"Training Random Forest...\\n\",\n",
    "      \"Training HistGBM...\\n\"\n",
    "     ]\n",
    "    },\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"text/plain\": [\n",
    "       \"                 Model  Train ROC-AUC  Val ROC-AUC  Std Val AUC\\n\",\n",
    "       \"2              HistGBM       0.978171     0.908990     0.006577\\n\",\n",
    "       \"1        Random Forest       1.000000     0.888608     0.004269\\n\",\n",
    "       \"0  Logistic Regression       0.866216     0.856260     0.005499\"\n",
    "      ],\n",
    "      \"text/html\": [\n",
    "       \"<div>\\n\",\n",
    "       \"<style scoped>\\n\",\n",
