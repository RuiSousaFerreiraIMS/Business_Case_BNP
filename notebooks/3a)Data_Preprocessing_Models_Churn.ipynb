    "     \"end_time\": \"2026-03-14T19:10:54.433352200Z\",\n",
    "     \"start_time\": \"2026-03-14T19:10:54.381671700Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Define target and columns to exclude\\n\",\n",
    "    \"\\n\",\n",
    "    \"target = 'IS_CHURN'          # churn label (related outcome)\\n\",\n",
    "    \"\\n\",\n",
    "    \"drop_cols = [\\n\",\n",
    "    \"    # Target and direct leakage\\n\",\n",
    "    \"    target,                   # the label itself\\n\",\n",
    "    \"    'EVER_SAN',               # leak: directly reveals SAN history\\n\",\n",
    "    \"    'EVER_SOL',               # leak: directly reveals SOL history\\n\",\n",
    "    \"    'N_SAN',                  # leak: count of SAN events\\n\",\n",
    "    \"    'N_SOL',                  # leak: count of SOL events\\n\",\n",
    "    \"    'EVER_RBT',               # leak: reveals RBT (reimbursement) events\\n\",\n",
    "    \"    'N_RBT',                  # leak: count of RBT events\\n\",\n",
    "    \"    'IS_SAN',                 # leak: binary SAN flag\\n\",\n",
    "    \"    'IS_EARLY_SETTLER',  # 1 = SAN (early), 0 = SOL (on time)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Date columns with leakage risk\\n\",\n",
    "    \"    'LAST_OBS_DATE_SOL',      # leak: date of last SOL observation\\n\",\n",
    "    \"    'LAST_OBS_DATE_SAN',      # leak: date of last SAN observation\\n\",\n",
    "    \"    'LAST_OBS_DATE_RBT',      # leak: date of last RBT observation\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Phase 1 Leakage: Post-settlement BDOSS aggregations\\n\",\n",
    "    \"    'TOTAL_CRD',              # residual credit at last obs -> 0 after payoff\\n\",\n",
    "    \"    'TOTAL_SREC',             # recovery amount, only exists post-default\\n\",\n",
    "    \"    'TOTAL_RN',               # nominal remaining, changes at settlement\\n\",\n",
    "    \"    'TOTAL_RD',               # debt remaining, changes at settlement\\n\",\n",
    "    \"    'LAST_RISK',              # risk score at last observation (post-settlement)\\n\",\n",
    "    \"    'MAX_RISKA',              # max risk score (accumulates post-event info)\\n\",\n",
    "    \"    'LAST_DPOS',              # date of last POS observation, approx settlement date\\n\",\n",
    "    \"    'LAST_DATFIN',            # last contract end date, tied to settlement\\n\",\n",
    "    \"    'FIRST_D1FIN',            # first contract end date, tied to settlement\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Phase 2 Leakage: Temporal aggregations across client history (FAMA & CRC)\\n\",\n",
    "    \"    # These use `.last()`, `.min()`, `.max()` over post-settlement data.\\n\",\n",
    "    \"    'MT_MENSAL_MIN', 'MT_MENSAL_MAX',\\n\",\n",
    "    \"    'COUNT_CL_MIN', 'COUNT_CL_MAX',\\n\",\n",
    "    \"    'COUNT_AUTO_MIN', 'COUNT_AUTO_MAX',\\n\",\n",
    "    \"    'COUNT_TOTAL_MIN', 'COUNT_TOTAL_MAX',\\n\",\n",
    "    \"    'MONTVENC_CL_MIN', 'MONTVENC_CL_MAX',\\n\",\n",
    "    \"    'MONTVENC_CP_MIN', 'MONTVENC_CP_MAX',\\n\",\n",
    "    \"    'MONTVENC_AUTO_MIN', 'MONTVENC_AUTO_MAX',\\n\",\n",
    "    \"    'MONTVENC_HT_MIN', 'MONTVENC_HT_MAX', \\n\",\n",
    "    \"    'DIVIDAS_CL_MIN', 'DIVIDAS_CL_MAX',\\n\",\n",
    "    \"    'DIVIDAS_CP_MIN', 'DIVIDAS_CP_MAX',\\n\",\n",
    "    \"    'DIVIDAS_AUTO_MIN', 'DIVIDAS_AUTO_MAX',\\n\",\n",
    "    \"    'DIVIDAS_HT_MIN', 'DIVIDAS_HT_MAX',\\n\",\n",
    "    \"# adicionar os dividas_total etc\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Raw date columns (not model-ready)\\n\",\n",
    "    \"    'FIRST_DCREAT',           # date: first contract creation\\n\",\n",
    "    \"    'LAST_DCREAT',            # date: last contract creation\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Client ID (not predictive, just an identifier)\\n\",\n",
    "    \"    'CONTRIB'\\n\",\n",
    "    \"]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Drop columns (errors='ignore' handles cols absent in the data)\\n\",\n",
    "    \"X = mask_pay.drop(columns=drop_cols, errors='ignore')\\n\",\n",
    "    \"y = mask_pay[target]\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Sanity check: the target must be binary\\n\",\n",
    "    \"assert y.nunique() == 2, (\\n\",\n",
    "    \"    f\\\"Expected a binary target, but found {y.nunique()} unique values: {y.unique()}\\\"\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f'All specified leaky features explicitly dropped. Remaining columns: {X.shape[1]}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Stratified 80/20 split\\n\",\n",
    "    \"X_train, X_test, y_train, y_test = train_test_split(\\n\",\n",
    "    \"    X, y,\\n\",\n",
    "    \"    test_size=0.2,\\n\",\n",
    "    \"    stratify=y,                  # preserve the SAN/SOL ratio in both sets\\n\",\n",
    "    \"    random_state=RANDOM_STATE,\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f'\\\\nTrain : {X_train.shape} - Churn rate: {y_train.mean():.2%}')\\n\",\n",
    "    \"print(f'Test  : {X_test.shape}  - Churn rate: {y_test.mean():.2%}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Cross-validation strategy\\n\",\n",
    "    \"# 5-fold stratified CV keeps the class ratio stable across folds\\n\",\n",
    "    \"cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=RANDOM_STATE)\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"All specified leaky features explicitly dropped. Remaining columns: 40\\n\",\n",
    "      \"\\n\",\n",
    "      \"Train : (53952, 40) - Churn rate: 98.34%\\n\",\n",
    "      \"Test  : (13488, 40)  - Churn rate: 98.34%\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 6\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"fb0eb3e0\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3. Build Preprocessing Pipeline\\n\",\n",
    "    \"\\n\",\n",
    "    \"No model here - this pipeline only preprocesses the data.\\n\",\n",
    "    \"The model is added later after feature selection.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"15b24915\",\n",
    "   \"metadata\": {\n",
    "    \"execution\": {\n",
    "     \"iopub.execute_input\": \"2026-03-13T12:09:41.457551Z\",\n",
    "     \"iopub.status.busy\": \"2026-03-13T12:09:41.457380Z\",\n",
    "     \"iopub.status.idle\": \"2026-03-13T12:09:41.461489Z\",\n",
    "     \"shell.execute_reply\": \"2026-03-13T12:09:41.461089Z\"\n",
    "    },\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-14T19:10:54.454586200Z\",\n",
    "     \"start_time\": \"2026-03-14T19:10:54.436351600Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Assemble the preprocessing pipeline\\n\",\n",
    "    \"# Each step is a custom sklearn transformer defined in class_pipeline_functions.py.\\n\",\n",
    "    \"# They follow the fit/transform contract so that statistics are learned\\n\",\n",
    "    \"# on training data only and applied consistently to test data.\\n\",\n",
    "    \"\\n\",\n",
    "    \"preprocessing_pipe = Pipeline([\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Step 1: Cleaning\\n\",\n",
    "    \"    # Convert dtypes, remove unwanted columns, enforce numeric ranges.\\n\",\n",
    "    \"    # LAST_RISK and MAX_RISKA are no longer present (dropped as leaky),\\n\",\n",
    "    \"    # so numeric_ranges is empty.\\n\",\n",
    "    \"    ('cleaning', ClientDataCleaner(\\n\",\n",
    "    \"        datetime_cols  = [],\\n\",\n",
    "    \"        cols_to_remove = [],\\n\",\n",
    "    \"        numeric_ranges = {},\\n\",\n",
    "    \"        verbose        = True,\\n\",\n",
    "    \"    )),\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Step 2: Outlier detection and neutralisation\\n\",\n",
    "    \"    # Uses a multi-method voting approach (IQR + modified Z-score).\\n\",\n",
    "    \"    # A value must be flagged by at least 2 methods to be set to NaN.\\n\",\n",
    "    \"    # CSP is a discrete socio-professional code (10, 20, ..., 99);\\n\",\n",
    "    \"    # it must NOT be treated as a continuous variable for outlier detection.\\n\",\n",
    "    \"    ('outliers', ClientOutlierHandler(\\n\",\n",
    "    \"        methods      = ('iqr', 'mod_z'),\\n\",\n",
    "    \"        min_votes    = 2,\\n\",\n",
    "    \"        iqr_k        = 1.5,\\n\",\n",
    "    \"        exclude_cols = ['CSP'],\\n\",\n",
    "    \"        verbose      = True,\\n\",\n",
    "    \"    )),\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Step 3: Imputation\\n\",\n",
    "    \"    # Numeric: fill missing values with the median (robust to remaining outliers).\\n\",\n",
    "    \"    # Categorical: fill with 'Unknown'.\\n\",\n",
    "    \"    ('imputer', ClientImputer(\\n\",\n",
    "    \"        numeric_strategy  = 'median',\\n\",\n",
    "    \"        datetime_strategy = 'ffill', # doesn't matter because we have no datetime cols after dropping leaky features\\n\",\n",
    "    \"        verbose           = True,\\n\",\n",
    "    \"    )),\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ClientFeatureEngineer is intentionally skipped here because\\n\",\n",
    "    \"    # abt.parquet is already aggregated.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Step 4: One-Hot Encoding for categorical features\\n\",\n",
    "    \"    # Encodes sdem_SITFAM, sdem_HABITAT, and CSP into dummy variables.\\n\",\n",
    "    \"    ('encoder', ClientOneHotEncoder(\\n\",\n",
    "    \"        cols=['sdem_SITFAM', 'sdem_HABITAT', 'CSP'],\\n\",\n",
    "    \"        drop_first=False,\\n\",\n",
    "    \"        verbose=True,\\n\",\n",
    "    \"    )),\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Step 5: Scaling\\n\",\n",
    "    \"    # StandardScaler (z-score normalisation) on all numeric columns.\\n\",\n",
    "    \"    ('ct', ColumnTransformer([\\n\",\n",
    "    \"        ('num', RobustScaler(), make_column_selector(dtype_include='number'))\\n\",\n",
    "    \"    ], remainder='passthrough', verbose_feature_names_out=False)),\\n\",\n",
    "    \"])\\n\",\n",
    "    \"\\n\",\n",
    "    \"print('Pipeline built successfully')\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Pipeline built successfully\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 7\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"40a3a4ae\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. Fit & Transform\\n\",\n",
    "    \"\\n\",\n",
    "    \"- `fit_transform` on `X_train`: pipeline learns all statistics from training data only\\n\",\n",
    "    \"- `transform` on `X_test`: applies without learning anything new\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Never call `fit_transform` on `X_test`.**\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"d7471ab4\",\n",
    "   \"metadata\": {\n",
    "    \"execution\": {\n",
    "     \"iopub.execute_input\": \"2026-03-13T12:09:41.463746Z\",\n",
    "     \"iopub.status.busy\": \"2026-03-13T12:09:41.463607Z\",\n",
    "     \"iopub.status.idle\": \"2026-03-13T12:09:42.042377Z\",\n",
    "     \"shell.execute_reply\": \"2026-03-13T12:09:42.041935Z\"\n",
    "    },\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-14T19:10:54.818759700Z\",\n",
    "     \"start_time\": \"2026-03-14T19:10:54.455586700Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"# Fit on train, transform both \\n\",\n",
    "    \"# The pipeline learns all statistics (medians, IQR bounds, OHE categories,\\n\",\n",
    "    \"# scaler means/stds) from X_train during fit_transform().\\n\",\n",
    "    \"# X_test is only transformed - no information from it leaks into the pipeline.\\n\",\n",
    "    \"X_train_processed = preprocessing_pipe.fit_transform(X_train, y_train)\\n\",\n",
    "    \"X_test_processed  = preprocessing_pipe.transform(X_test)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Retrieve feature names from the ColumnTransformer\\n\",\n",
    "    \"feature_names = preprocessing_pipe.named_steps['ct'].get_feature_names_out()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Convert numpy arrays back to DataFrames for convenience\\n\",\n",
    "    \"X_train_df = pd.DataFrame(X_train_processed, columns=feature_names)\\n\",\n",
    "    \"X_test_df  = pd.DataFrame(X_test_processed,  columns=feature_names)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Quick sanity checks\\n\",\n",
    "    \"print(f'X_train processed : {X_train_df.shape}')\\n\",\n",
    "    \"print(f'X_test  processed : {X_test_df.shape}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"remaining_nans = X_train_df.isna().sum().sum()\\n\",\n",
    "    \"print(f'Any NaNs remaining: {remaining_nans}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Warn if any NaNs survived the pipeline (should be 0)\\n\",\n",
    "    \"if remaining_nans > 0:\\n\",\n",
    "    \"    print(\\\"WARNING: NaN values remain after preprocessing - check the pipeline!\\\")\"\n",
    "   ],\n",
