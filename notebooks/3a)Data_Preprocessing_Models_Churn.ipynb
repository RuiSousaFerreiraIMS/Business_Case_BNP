    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"\\n\",\n",
    "      \"Selected HistGBM as the best baseline model.\\n\",\n",
    "      \"CAUTION!  HistGBM: train-val gap = 0.0692 - possible overfitting\\n\",\n",
    "      \"CAUTION!  Random Forest: train-val gap = 0.1114 - possible overfitting\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 10\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"id\": \"827795b3\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7. Hyperparameter Tuning\\n\",\n",
    "    \"\\n\",\n",
    "    \"Run `RandomizedSearchCV` on the best model from Section 6.\\n\",\n",
    "    \"Still using only `X_train_fs`. `X_test_fs` remains untouched.\\n\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"52f28f05\",\n",
    "   \"metadata\": {\n",
    "    \"execution\": {\n",
    "     \"iopub.execute_input\": \"2026-03-13T12:10:18.715800Z\",\n",
    "     \"iopub.status.busy\": \"2026-03-13T12:10:18.715565Z\",\n",
    "     \"iopub.status.idle\": \"2026-03-13T12:11:47.552595Z\",\n",
    "     \"shell.execute_reply\": \"2026-03-13T12:11:47.551436Z\"\n",
    "    },\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-14T19:14:57.170671100Z\",\n",
    "     \"start_time\": \"2026-03-14T19:11:34.297372Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"print(f\\\"Tuning {best_model_name}...\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"if best_model_name == 'HistGBM':\\n\",\n",
    "    \"    param_distributions = {\\n\",\n",
    "    \"        'model__learning_rate':     loguniform(0.01, 0.2),\\n\",\n",
    "    \"        'model__max_iter':          randint(100, 300),\\n\",\n",
    "    \"        'model__max_depth':         randint(3, 10),\\n\",\n",
    "    \"        'model__min_samples_leaf':  randint(10, 50),\\n\",\n",
    "    \"        'model__l2_regularization': loguniform(1e-4, 10.0),\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"elif best_model_name == 'Random Forest':\\n\",\n",
    "    \"    param_distributions = {\\n\",\n",
    "    \"        'model__n_estimators':      randint(100, 300),\\n\",\n",
    "    \"        'model__max_depth':         randint(5, 20),\\n\",\n",
    "    \"        'model__min_samples_split': randint(2, 20),\\n\",\n",
    "    \"        'model__min_samples_leaf':  randint(1, 10),\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"else:  # Logistic Regression\\n\",\n",
    "    \"    param_distributions = {\\n\",\n",
    "    \"        'model__C':      loguniform(1e-3, 1e2),\\n\",\n",
    "    \"        'model__solver': ['liblinear', 'saga'],\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"# O resto fica IGUAL\\n\",\n",
    "    \"search = RandomizedSearchCV(\\n\",\n",
    "    \"    best_model,\\n\",\n",
    "    \"    param_distributions=param_distributions,\\n\",\n",
    "    \"    n_iter=50,\\n\",\n",
    "    \"    scoring='roc_auc',\\n\",\n",
    "    \"    cv=cv,\\n\",\n",
    "    \"    verbose=1,\\n\",\n",
    "    \"    random_state=RANDOM_STATE,\\n\",\n",
    "    \"    n_jobs=-1,\\n\",\n",
    "    \")\\n\",\n",
    "    \"search.fit(X_train_fs, y_train)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Best ROC-AUC: {search.best_score_:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"Best parameters: {search.best_params_}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"final_model = search.best_estimator_\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"Tuning HistGBM...\\n\",\n",
    "      \"Fitting 5 folds for each of 50 candidates, totalling 250 fits\\n\",\n",
    "      \"Best ROC-AUC: 0.9092\\n\",\n",
    "      \"Best parameters: {'model__l2_regularization': np.float64(1.6698184041729127), 'model__learning_rate': np.float64(0.09381793717496219), 'model__max_depth': 9, 'model__max_iter': 152, 'model__min_samples_leaf': 33}\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
