    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 8. Final Evaluation on Test Set\\n\",\n",
    "    \"\\n\",\n",
    "    \"**This section runs only once at the very end.**\\n\",\n",
    "    \"The test set was never used for any decision up to this point.\\n\"\n",
    "   ]\n",
    "  },\n",
