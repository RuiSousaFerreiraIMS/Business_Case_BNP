    "    \"# Generate predictions on the held-out test set\\n\",\n",
    "    \"# final_model was defined in Section 7 as the best estimator from RandomizedSearchCV\\n\",\n",
    "    \"y_pred      = final_model.predict(X_test_fs)             # hard labels (0/1)\\n\",\n",
    "    \"y_pred_prob = final_model.predict_proba(X_test_fs)[:, 1] # probability of class 1 (SAN)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Print headline metrics\\n\",\n",
    "    \"print('=' * 50)\\n\",\n",
    "    \"print('FINAL TEST SET RESULTS')\\n\",\n",
    "    \"print('=' * 50)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ROC-AUC - primary ranking metric\\n\",\n",
    "    \"roc_auc = roc_auc_score(y_test, y_pred_prob)\\n\",\n",
    "    \"print(f'ROC-AUC  : {roc_auc:.4f}')\\n\",\n",
    "    \"print()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Classification report - precision, recall, F1 per class\\n\",\n",
    "    \"print(classification_report(y_test, y_pred, target_names=[\\\"Renewal\\\", 'Churn']))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Confusion matrix\\n\",\n",
    "    \"fig, ax = plt.subplots(figsize=(6, 5))\\n\",\n",
    "    \"ConfusionMatrixDisplay.from_predictions(\\n\",\n",
    "    \"    y_test, y_pred,\\n\",\n",
